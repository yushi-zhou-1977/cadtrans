<UserControl x:Class="MyPlugin.CadTransPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Microsoft YaHei UI, Segoe UI"
             FontSize="12">

    <UserControl.Resources>
        <!-- 主题色按钮样式（蓝色渐变） -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1976D2" Offset="0"/>
                        <GradientStop Color="#0D47A1" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#1E88E5" Offset="0"/>
                                            <GradientStop Color="#1565C0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#0D47A1" Offset="0"/>
                                            <GradientStop Color="#0A3A8A" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 次要按钮样式（灰色） -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#BDBDBD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#9E9E9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 成功按钮样式（绿色渐变） -->
        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#43A047" Offset="0"/>
                        <GradientStop Color="#2E7D32" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#4CAF50" Offset="0"/>
                                            <GradientStop Color="#388E3C" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#2E7D32" Offset="0"/>
                                            <GradientStop Color="#1B5E20" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 输入框样式 -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- 下拉框样式 -->
        <Style x:Key="InputCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- 区域卡片样式 -->
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.15" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 区域标题 -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#37474F"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- 字段标签 -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#757575"/>
            <Setter Property="Margin" Value="0,6,0,2"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8">

            <!-- 渐变色标题栏 -->
            <Border CornerRadius="6" Padding="14,12" Margin="0,0,0,10">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A237E" Offset="0"/>
                        <GradientStop Color="#0288D1" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock Text="CadTrans" Foreground="White" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="CAD 翻译助手" Foreground="#B3E5FC" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- 翻译区域 -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="翻译" Style="{StaticResource SectionTitle}"/>

                    <!-- 翻译额度显示条 -->
                    <Border Background="#E3F2FD" CornerRadius="4" Padding="8,6" Margin="0,0,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" FontSize="11" Foreground="#1565C0" Margin="0,0,0,2">
                                <Run Text="授权类型: "/><Run Text="{Binding LicenseTypeDisplay, Mode=OneWay}" FontWeight="SemiBold"/>
                                <Run Text=" | "/><Run Text="{Binding QuotaSourceText, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Grid.Row="1" FontSize="11" Foreground="#1565C0" Margin="0,0,0,4">
                                <Run Text="今日额度: "/><Run Text="{Binding QuotaUsed, Mode=OneWay}" FontWeight="SemiBold"/><Run Text=" / "/><Run Text="{Binding QuotaTotal, Mode=OneWay}" FontWeight="SemiBold"/><Run Text=" 字符"/>
                            </TextBlock>
                            <ProgressBar Grid.Row="2" Height="8" Minimum="0" Maximum="100"
                                         Value="{Binding QuotaPercent, Mode=OneWay}"
                                         Foreground="#1976D2" Background="#BBDEFB"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="源语言" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Style="{StaticResource InputCombo}"
                              SelectedIndex="{Binding SourceLangIndex, Mode=TwoWay}"
                              Margin="0,0,0,4">
                        <ComboBoxItem Content="简体中文"/>
                        <ComboBoxItem Content="越南语"/>
                        <ComboBoxItem Content="印尼语"/>
                        <ComboBoxItem Content="英语"/>
                        <ComboBoxItem Content="日语"/>
                        <ComboBoxItem Content="韩语"/>
                        <ComboBoxItem Content="泰语"/>
                        <ComboBoxItem Content="法语"/>
                        <ComboBoxItem Content="德语"/>
                        <ComboBoxItem Content="西班牙语"/>
                        <ComboBoxItem Content="俄语"/>
                    </ComboBox>

                    <TextBlock Text="目标语言" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Style="{StaticResource InputCombo}"
                              SelectedIndex="{Binding TargetLangIndex, Mode=TwoWay}"
                              Margin="0,0,0,4">
                        <ComboBoxItem Content="简体中文"/>
                        <ComboBoxItem Content="越南语"/>
                        <ComboBoxItem Content="印尼语"/>
                        <ComboBoxItem Content="英语"/>
                        <ComboBoxItem Content="日语"/>
                        <ComboBoxItem Content="韩语"/>
                        <ComboBoxItem Content="泰语"/>
                        <ComboBoxItem Content="法语"/>
                        <ComboBoxItem Content="德语"/>
                        <ComboBoxItem Content="西班牙语"/>
                        <ComboBoxItem Content="俄语"/>
                    </ComboBox>

                    <TextBlock Text="翻译模式" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Style="{StaticResource InputCombo}"
                              SelectedIndex="{Binding TranslateModeIndex, Mode=TwoWay}"
                              Margin="0,0,0,8">
                        <ComboBoxItem Content="新建（原文下方）"/>
                        <ComboBoxItem Content="替换（替换原文）"/>
                    </ComboBox>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="快速翻译"
                                Style="{StaticResource SuccessButton}"
                                Command="{Binding QuickTranslateCommand}"/>
                        <Button Grid.Column="2" Content="完整翻译"
                                Style="{StaticResource AccentButton}"
                                Command="{Binding FullTranslateCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 设置区域 -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="设置" Style="{StaticResource SectionTitle}"/>

                    <TextBlock Text="邮箱（50K套餐必需）" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource InputBox}"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,4"/>

                    <TextBlock Text="文本高度：自动跟随原文" FontSize="11" Foreground="#9E9E9E" Margin="0,2,0,2"/>
                    <TextBlock Text="偏移距离：自动1倍字体高度" FontSize="11" Foreground="#9E9E9E" Margin="0,2,0,8"/>

                    <Button Content="保存设置"
                            Style="{StaticResource SecondaryButton}"
                            HorizontalAlignment="Stretch"
                            Command="{Binding SaveSettingsCommand}"/>
                </StackPanel>
            </Border>

            <!-- 授权区域 -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="授权" Style="{StaticResource SectionTitle}"/>

                    <TextBlock Text="许可证密钥" Style="{StaticResource FieldLabel}"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource InputBox}"
                                 Text="{Binding LicenseKey, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="2" Content="激活"
                                Style="{StaticResource AccentButton}"
                                Padding="14,4"
                                Command="{Binding ActivateLicenseCommand}"/>
                    </Grid>

                    <Button Content="查看授权状态"
                            Style="{StaticResource SecondaryButton}"
                            HorizontalAlignment="Stretch"
                            Command="{Binding CheckLicenseCommand}"
                            Margin="0,0,0,8"/>

                    <Border Background="#F5F5F5" CornerRadius="4" Padding="8" MinHeight="70">
                        <TextBlock Text="{Binding StatusText}"
                                   TextWrapping="Wrap"
                                   FontSize="11"
                                   Foreground="#616161"
                                   LineHeight="18"/>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
